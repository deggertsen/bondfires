{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/*.json",
      "!**/*.cjs",
      "!**/*.css",
      "!**/*.js",
      "!**/*.d.ts",
      "!**/*.config.ts",
      "!**/generated/**/*",
      "!**/dist",
      "!**/build",
      "!**/out",
      "!**/.next",
      "!**/node_modules"
    ]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "useSimplifiedLogicExpression": "off"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": {
          "level": "error",
          "fix": "none"
        },
        "noSwitchDeclarations": "off"
      },
      "style": {
        "noImplicitBoolean": "off",
        "useBlockStatements": "off",
        "useNamingConvention": "off",
        "noNonNullAssertion": "error"
      },
      "suspicious": {
        "noShadowRestrictedNames": "off",
        "noExplicitAny": "error",
        "noConsole": {
          "level": "error",
          "fix": "none",
          "options": {
            "allow": ["assert", "error", "info", "warn"]
          }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single"
    },
    "globals": ["JSX", "expect", "describe", "beforeAll", "afterAll", "jest"]
  }
}

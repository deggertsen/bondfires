{
  "expo": {
    "name": "Bondfires",
    "slug": "bondfires",
    "version": "1.0.55",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bondfires",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFA",
      "dark": {
        "backgroundColor": "#141416"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.bondfires",
      "buildNumber": "69",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:bondfires.org",
        "applinks:bondfires.app"
      ],
      "entitlements": {
        "com.apple.developer.associated-domains": [
          "applinks:bondfires.org",
          "applinks:bondfires.app"
        ]
      },
      "infoPlist": {
        "AppStoreID": "6755933598",
        "NSCameraUsageDescription": "Bondfires needs access to your camera to record videos for your bondfire sessions.",
        "NSMicrophoneUsageDescription": "Bondfires needs access to your microphone to record audio with your videos.",
        "NSPhotoLibraryUsageDescription": "Bondfires needs access to your photo library to save and share videos from your bondfire sessions.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "org.bondfires",
      "versionCode": 69,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#141416"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "bondfires.org",
              "pathPrefix": "/personal-bondfire"
            },
            {
              "scheme": "https",
              "host": "bondfires.app",
              "pathPrefix": "/personal-bondfire"
            },
            {
              "scheme": "https",
              "host": "bondfires.org",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "bondfires.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "Bondfires needs access to your camera to record videos for your bondfire sessions.",
          "microphonePermission": "Bondfires needs access to your microphone to record audio with your videos.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Bondfires needs access to your microphone to record audio with your videos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF6B35"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "flipper": false,
            "useFrameworks": "static"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "expo-video",
      "expo-font",
      "expo-iap",
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fbb59011-a987-492b-90fa-421481f1597b"
      }
    },
    "owner": "deggertsen"
  }
}

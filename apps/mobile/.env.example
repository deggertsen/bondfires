# Convex - Replace with your actual deployment URL after running npx convex dev
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Auth email is server-side. Set RESEND_API_KEY and EMAIL_FROM in Convex, not here.
# The EMAIL_FROM domain must be verified in Resend with SPF and DKIM passing.

# Mux credentials and live-streaming settings are server-side Convex environment variables,
# not Expo public env. Set MUX_TOKEN_ID, MUX_TOKEN_SECRET, MUX_WEBHOOK_SECRET,
# optional MUX_LIVE_LATENCY_MODE=low, optional MUX_LIVE_RECONNECT_WINDOW_SECONDS=30,
# and optional MUX_LIVE_RECONNECT_SLATE_URL=<public png/jpg URL> in Convex.

# MUX Data env key (public — used client-side by the MUX Data SDK for QoE monitoring)
# Get this from https://data.mux.com → Settings → Environment Key
# Included free for all MUX-hosted video streams.
EXPO_PUBLIC_MUX_DATA_ENV_KEY=your-mux-data-env-key

# Phase 1 local MP4 safety copy for live recordings. Default off.
EXPO_PUBLIC_LOCAL_BACKUP_RECORDING=0

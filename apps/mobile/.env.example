# Convex - Replace with your actual deployment URL after running npx convex dev
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Auth email is server-side. Set RESEND_API_KEY and EMAIL_FROM in Convex, not here.
# The EMAIL_FROM domain must be verified in Resend with SPF and DKIM passing.

# Mux credentials and live-streaming settings are server-side Convex environment variables,
# not Expo public env. Set MUX_TOKEN_ID, MUX_TOKEN_SECRET, MUX_WEBHOOK_SECRET,
# optional MUX_LIVE_LATENCY_MODE=low, and optional MUX_LIVE_RECONNECT_WINDOW_SECONDS=30 in Convex.

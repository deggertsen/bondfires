{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@bondfires/app": ["../../packages/app/src"],
      "@bondfires/config": ["../../packages/config/src"],
      "@bondfires/ui": ["../../packages/ui/src"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "../../convex/**/*.ts"
  ]
}
